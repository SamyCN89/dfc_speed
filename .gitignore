# ============================================================
# dfc_speed — .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ------------------------------------------------------------
# Jupyter / IPython
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ------------------------------------------------------------
# Data files (heavy, never track raw data in git)
# ------------------------------------------------------------
*.mat
*.npz
*.npy
*.csv
*.h5
*.hdf5
*.pkl
*.pickle

# ------------------------------------------------------------
# Figures / outputs (regenerable)
# ------------------------------------------------------------
*.png
*.pdf
*.svg
*.eps
*.tiff
*.tif

# ------------------------------------------------------------
# Project-specific
# ------------------------------------------------------------
TEMP/
data/
*.zip
code.zip

# ------------------------------------------------------------
# Testing
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ------------------------------------------------------------
# Editors / IDEs
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Environments
# ------------------------------------------------------------
.env
.venv/
venv/
env/
